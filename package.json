{
  "name": "persona-counsel-workspace",
  "private": true,
  "version": "0.0.0",
  "description": "Workspace for persona-counsel npm namespace placeholders",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "pr:open": "bash ./scripts/pr_open.sh --pr",
    "pr:open:pr": "bash ./scripts/pr_open.sh --pr",
    "pr:open:r": "bash ./scripts/pr_open.sh --r",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run",
    "release:queue": "bash ./scripts/release_queue_ci.sh",
    "release:reset": "node scripts/release_reset.mjs",
    "build": "npm run -ws build --if-present",
    "test": "npm run -ws test --if-present"
  }
}
